{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kodo.local/schemas/code-review-round-result.json",
  "title": "Code Review Round Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "round",
    "scope",
    "fixed_findings",
    "remaining_findings",
    "validation",
    "blocked_reason",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": ["clear", "continue", "blocked"]
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "fixed_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixedFinding"
      }
    },
    "remaining_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/remainingFinding"
      }
    },
    "validation": {
      "$ref": "#/$defs/validation"
    },
    "blocked_reason": {
      "type": ["string", "null"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^.+:\\d+(?::\\d+)?$"
      }
    },
    "fixedFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "severity", "files", "evidence", "validation"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "remainingFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "severity", "risk", "evidence", "fix_direction"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "risk": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "fix_direction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ran", "passed", "failures"],
      "properties": {
        "ran": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "passed": {
          "type": "boolean"
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
