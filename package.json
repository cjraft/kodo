{
  "name": "kodo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A local coding agent CLI with an Ink TUI.",
  "bin": {
    "kodo": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --target node22 --out-dir dist --clean",
    "start": "node dist/index.js",
    "smoke:provider": "tsx scripts/provider-smoke-test.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.65.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "envalid": "^8.1.1",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
